# EDITH Local/Cloud Split Architecture — Environment Variables
# Copy this file to .env, .env.local, or .env.cloud and fill in your values

# ────────────────────────────────────────────────
# BRIDGE AUTHENTICATION (REQUIRED)
# ────────────────────────────────────────────────
# Shared secret token used by local and cloud nodes to authenticate HTTP calls
# Change this to a secure random string before deployment
BRIDGE_SECRET=change_me_to_secure_token

# ────────────────────────────────────────────────
# LOCAL NODE CONFIGURATION
# ────────────────────────────────────────────────
# Used by local_bridge.py and background_daemon_local.py

# Public IP or hostname of cloud node (so local can reach it)
CLOUD_URL=http://localhost:8001
# ^ For Docker: http://cloud-node:8001
# ^ For production: https://cloud.example.com

# Port for local bridge API (on which wake_listener will POST transcriptions)
LOCAL_BRIDGE_PORT=8002

# ────────────────────────────────────────────────
# CLOUD NODE CONFIGURATION
# ────────────────────────────────────────────────
# Used by chat_server.py, orchestrator.py, background_daemon_cloud.py

# Public IP or hostname of local hardware node (so cloud can reach it)
LOCAL_IP=192.168.x.x
# ^ For Docker: http://local-node:8002
# ^ For production: http://192.168.1.100 (local network)

# Full URL to local bridge API
LOCAL_BRIDGE_URL=http://local-node:8002
# ^ Cloud uses this to call speak(), mic/pause, mic/resume

# ────────────────────────────────────────────────
# LLM PROVIDER KEYS
# ────────────────────────────────────────────────
# Leave blank to disable a provider. smart_router will use first available.

# Groq (Deprecated but supported)
GROQ_API_KEY=

# OpenAI
OPENAI_API_KEY=

# Google Gemini
GEMINI_API_KEY=

# NVIDIA NIM
NVIDIA_API_KEY=

# OpenRouter (fallback aggregator)
OPENROUTER_API_KEY=

# ────────────────────────────────────────────────
# COMMUNICATION
# ────────────────────────────────────────────────

# Telegram Bot Token (for system alerts, briefings, self-improve notifications)
TELEGRAM_BOT_TOKEN=

# Gmail OAuth Service Account JSON (for calendar + email reading)
# This is the file path to your service_account.json
GMAIL_SERVICE_ACCOUNT_JSON=./credentials.json

# ────────────────────────────────────────────────
# DATABASE & STORAGE
# ────────────────────────────────────────────────

# ChromaDB path (cloud node)
MEMORY_DB_PATH=./memory_db

# SQLite archive path (cloud node)
MEMORY_ARCHIVE_PATH=./memory_db_archive.db

# ────────────────────────────────────────────────
# HARDWARE (LOCAL NODE ONLY)
# ────────────────────────────────────────────────

# X11 display for PyQt6 widget (local node)
DISPLAY=:0

# Ollama API endpoint (local or cloud, depending on deployment)
OLLAMA_HOST=http://localhost:11434

# ────────────────────────────────────────────────
# VOICE OPTIONS
# ────────────────────────────────────────────────

# TTS engine preference
USE_GROQ_TTS=true
USE_CHATTERBOX=false
PREFER_FAST_TTS=true

# Voice triggers (for voice.py mode switching)
FRIEND_VOICE_TRIGGER=friend mode
NORMAL_VOICE_TRIGGER=normal mode

# ────────────────────────────────────────────────
# OPTIONAL: KDE CONNECT (PUSH NOTIFICATIONS)
# ────────────────────────────────────────────────

# Device ID of phone/tablet for KDE Connect notifications
KDE_DEVICE_ID=

# ────────────────────────────────────────────────
# OPTIONAL: MOBILE DEVICE INTEGRATION
# ────────────────────────────────────────────────

# WhatsApp integration (via WhatsApp Business API or automation)
WHATSAPP_PHONE_NUMBER=

# ────────────────────────────────────────────────
# LOGGING & DEBUG
# ────────────────────────────────────────────────

LOG_LEVEL=INFO
PYTHONUNBUFFERED=1

# ────────────────────────────────────────────────
# DEPLOYMENT-SPECIFIC NOTES
# ────────────────────────────────────────────────

# For LOCAL development (single machine):
# - Use CLOUD_URL=http://localhost:8001
# - Use LOCAL_BRIDGE_URL=http://localhost:8002
# - Keep BRIDGE_SECRET consistent across components

# For DOCKER deployment (docker-compose.phase1-test.yml):
# - Use CLOUD_URL=http://cloud-node:8001
# - Use LOCAL_BRIDGE_URL=http://local-node:8002
# - Docker network: edith-net

# For PRODUCTION:
# - LOCAL: runs on Manjaro PC w/ hardware (GPU, mic, speakers)
#   - CLOUD_URL=https://cloud.edith.example.com
#   - Use HTTPS + valid BRIDGE_SECRET
# - CLOUD: runs on Debian server, headless
#   - LOCAL_BRIDGE_URL=https://local.edith.example.com or IP
#   - Use HTTPS + TLS certificates
